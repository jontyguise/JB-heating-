// ─── Enquiry backend via Claude API ──────────────────────────────
async function submitEnquiry(formData) {
  const prompt = `You are the backend processor for JB Heating Services, a professional heating engineer based in the YO43 area with a 4.7 star rating and 23+ years experience.

A customer has submitted an enquiry. Please:
1. Acknowledge their specific enquiry warmly and professionally
2. Give a realistic expected response time (same day for urgent, 1-2 business days otherwise)
3. If they mentioned an emergency (no heating, gas leak, boiler breakdown), flag it as URGENT and advise calling directly
4. Keep it to 3-4 sentences max, conversational, signed off as "JB Heating Services"

Customer enquiry details:
Name: ${formData.name}
Phone: ${formData.phone}
Service needed: ${formData.service}
Message: ${formData.message}

Respond ONLY with the confirmation message text, no JSON, no extra formatting.`;

  const response = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      messages: [{ role: "user", content: prompt }],
    }),
  });

  const data = await response.json();
  return data.content?.[0]?.text || "Thanks for your enquiry — we'll be in touch shortly.";
}

