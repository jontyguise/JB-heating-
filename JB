function EnquiryModal({ isOpen, onClose }) {
  const [form, setForm] = useState({ name: "", phone: "", service: "", message: "" });
  const [status, setStatus] = useState("idle"); // idle | submitting | success | error
  const [confirmMsg, setConfirmMsg] = useState("");
  const overlayRef = useRef();

  useEffect(() => {
    if (isOpen) document.body.style.overflow = "hidden";
    else document.body.style.overflow = "";
    return () => { document.body.style.overflow = ""; };
  }, [isOpen]);

  if (!isOpen) return null;

  const handleChange = (field, value) => setForm(f => ({ ...f, [field]: value }));

  const handleSubmit = async () => {
    if (!form.name || !form.phone || !form.service) return;
    setStatus("submitting");
    try {
      const msg = await submitEnquiry(form);
      setConfirmMsg(msg);
      setStatus("success");
    } catch {
      setStatus("error");
    }
  };

  return (
    <div
      ref={overlayRef}
      onClick={e => { if (e.target === overlayRef.current) onClose(); }}
      style={{
        position: "fixed", inset: 0, zIndex: 200,
        background: "rgba(11,31,58,0.75)", backdropFilter: "blur(4px)",
        display: "flex", alignItems: "center", justifyContent: "center",
        padding: "20px 16px",
      }}
    >
      <div style={{
        background: COLORS.white, borderRadius: 16, width: "100%", maxWidth: 520,
        maxHeight: "90vh", overflowY: "auto",
        boxShadow: "0 24px 80px rgba(11,31,58,0.3)",
      }}>
        {/* Header */}
        <div style={{
          background: `linear-gradient(135deg, ${COLORS.navy} 0%, #1A3A6E 100%)`,
          padding: "28px 32px", borderRadius: "16px 16px 0 0",
          display: "flex", justifyContent: "space-between", alignItems: "flex-start",
        }}>
          <div>
            <h2 style={{ fontFamily: "'Barlow Condensed', sans-serif", fontWeight: 800, fontSize: 28, color: COLORS.white, margin: "0 0 6px", letterSpacing: -0.3 }}>
              Get a Free Quote
            </h2>
            <p style={{ fontFamily: "Inter, sans-serif", fontSize: 14, color: "rgba(255,255,255,0.65)", margin: 0 }}>
              Fill in your details and we'll get back to you quickly.
            </p>
          </div>
          <button onClick={onClose} style={{
            background: "rgba(255,255,255,0.1)", border: "none", borderRadius: 8,
            width: 36, height: 36, display: "flex", alignItems: "center", justifyContent: "center",
            cursor: "pointer", flexShrink: 0,
          }}>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 2l10 10M12 2L2 12" stroke="white" strokeWidth="2" strokeLinecap="round"/>
            </svg>
          </button>
        </div>

        <div style={{ padding: "32px" }}>
          {status === "success" ? (
            <div style={{ textAlign: "center", padding: "16px 0" }}>
              <div style={{ fontSize: 52, marginBottom: 16 }}>✅</div>
              <h3 style={{ fontFamily: "'Barlow Condensed', sans-serif", fontWeight: 700, fontSize: 26, color: COLORS.navy, margin: "0 0 16px" }}>
                Enquiry Received!
              </h3>
              <p style={{ fontFamily: "Inter, sans-serif", fontSize: 15, color: COLORS.slate, lineHeight: 1.7, margin: "0 0 28px" }}>
                {confirmMsg}
              </p>
              <button onClick={onClose} style={{
                background: COLORS.blue, color: COLORS.white, border: "none",
                borderRadius: 8, padding: "12px 32px", fontFamily: "Inter, sans-serif",
                fontSize: 15, fontWeight: 600, cursor: "pointer",
              }}>Close</button>
            </div>
          ) : (
            <>
              {[
                { label: "Your Name *", field: "name", type: "text", placeholder: "e.g. John Smith" },
                { label: "Phone Number *", field: "phone", type: "tel", placeholder: "e.g. 07700 900123" },
              ].map(({ label, field, type, placeholder }) => (
                <div key={field} style={{ marginBottom: 20 }}>
                  <label style={{ fontFamily: "Inter, sans-serif", fontSize: 13, fontWeight: 600, color: COLORS.navy, display: "block", marginBottom: 6 }}>{label}</label>
                  <input
                    type={type}
                    placeholder={placeholder}
                    value={form[field]}
                    onChange={e => handleChange(field, e.target.value)}
                    style={{
                      width: "100%", padding: "11px 14px", borderRadius: 8,
                      border: `1.5px solid ${COLORS.steel}`, fontFamily: "Inter, sans-serif",
                      fontSize: 15, color: COLORS.text, boxSizing: "border-box",
                      outline: "none", transition: "border-color 0.2s",
                    }}
                    onFocus={e => e.target.style.borderColor = COLORS.blue}
                    onBlur={e => e.target.style.borderColor = COLORS.steel}
                  />
                </div>
              ))}

              <div style={{ marginBottom: 20 }}>
                <label style={{ fontFamily: "Inter, sans-serif", fontSize: 13, fontWeight: 600, color: COLORS.navy, display: "block", marginBottom: 6 }}>Service Required *</label>
                <select
                  value={form.service}
                  onChange={e => handleChange("service", e.target.value)}
                  style={{
                    width: "100%", padding: "11px 14px", borderRadius: 8,
                    border: `1.5px solid ${COLORS.steel}`, fontFamily: "Inter, sans-serif",
                    fontSize: 15, color: form.service ? COLORS.text : COLORS.slate,
                    boxSizing: "border-box", background: COLORS.white, outline: "none",
                  }}
                >
                  <option value="">Select a service...</option>
                  <option>Boiler Installation</option>
                  <option>Boiler Service / Annual Check</option>
                  <option>Boiler Repair / Breakdown</option>
                  <option>Central Heating Installation</option>
                  <option>Central Heating Repair</option>
                  <option>Hot Water System</option>
                  <option>Landlord Gas Safety Certificate</option>
                  <option>Power Flush</option>
                  <option>Other / Not Sure</option>
                </select>
              </div>

              <div style={{ marginBottom: 28 }}>
                <label style={{ fontFamily: "Inter, sans-serif", fontSize: 13, fontWeight: 600, color: COLORS.navy, display: "block", marginBottom: 6 }}>Tell Us More (optional)</label>
                <textarea
                  placeholder="Describe the issue or job, e.g. 'Boiler losing pressure and not firing up...'"
                  value={form.message}
                  onChange={e => handleChange("message", e.target.value)}
                  rows={4}
                  style={{
                    width: "100%", padding: "11px 14px", borderRadius: 8,
                    border: `1.5px solid ${COLORS.steel}`, fontFamily: "Inter, sans-serif",
                    fontSize: 14, color: COLORS.text, resize: "vertical", boxSizing: "border-box",
                    outline: "none", transition: "border-color 0.2s",
                  }}
                  onFocus={e => e.target.style.borderColor = COLORS.blue}
                  onBlur={e => e.target.style.borderColor = COLORS.steel}
                />
              </div>

              {status === "error" && (
                <div style={{ background: "#FEE2E2", border: "1px solid #FECACA", borderRadius: 8, padding: "12px 16px", marginBottom: 16, fontFamily: "Inter, sans-serif", fontSize: 14, color: "#991B1B" }}>
                  Something went wrong. Please call us directly.
                </div>
              )}

              <button
                onClick={handleSubmit}
                disabled={status === "submitting" || !form.name || !form.phone || !form.service}
                style={{
                  width: "100%", background: !form.name || !form.phone || !form.service ? "#94A3B8" : COLORS.blue,
                  color: COLORS.white, border: "none", borderRadius: 8, padding: "14px",
                  fontFamily: "Inter, sans-serif", fontSize: 16, fontWeight: 700,
                  cursor: !form.name || !form.phone || !form.service ? "not-allowed" : "pointer",
                  transition: "background 0.2s",
                }}
              >
                {status === "submitting" ? "Sending..." : "Send Enquiry →"}
              </button>

              <p style={{ fontFamily: "Inter, sans-serif", fontSize: 12, color: COLORS.slate, textAlign: "center", margin: "14px 0 0" }}>
                Or call us directly: <a href="tel:+441234567890" style={{ color: COLORS.blue, fontWeight: 600 }}>01234 567 890</a>
              </p>
            </>
          )}
        </div>
      </div>
    </div>
  );
}

